{
  "name": "mimusic-plugin-toolchain",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "eslint packages/*/src --ext .ts",
    "clean": "pnpm -r exec rm -rf dist",
    "changeset": "changeset",
    "version": "changeset version",
    "tag": "changeset tag",
    "release": "pnpm run build && changeset publish",
    "release:local": "changeset version && git add -A && git commit -m \"chore(release): version packages\" && changeset tag && git push --follow-tags"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "eslint": "^9.0.0",
    "typescript": "^5.7.0"
  }
}
